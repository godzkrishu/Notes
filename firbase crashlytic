class AppInitializer{
  static Future<void> init() async {
    // 🔥 External Dependencies
    await _initFirebase();
    await FirebaseCrashlytics.instance.setCrashlyticsCollectionEnabled(!kDebugMode);
    await _initHive();
    // 🔥 System settings
    await SystemChrome.setPreferredOrientations([
      DeviceOrientation.portraitUp,
    ]);
  }

  static Future<void> _initFirebase() async {
    await Firebase.initializeApp();
   //// cant use  await _notificationService.init(ref); because  it need ref so it only called inside MyApp
  }

  static Future<void>_initHive() async{
    await Hive.initFlutter();
    Hive.registerAdapter(UserModelAdapter());
    Hive.registerAdapter(TaskAdapter());
    await Hive.openBox<UserModel>('userBox');
    await Hive.openBox<Task>('tasksBox');
  }
}

###################2) Set the Loging and  logout tracking##################

  Future<void> login(
    BuildContext context,
    String email,
    String password,
  ) async {
    state = const AsyncValue.loading();

    try {
      final token = await AuthServices().login(email, password);
      if (token != null) {
        final user = await UserRepository.FetchAndSaveUser(token);
        if (user != null) {
          ref.read(userProvider.notifier).state = user;
          /// set the  data so that i can know who is calling what
          FirebaseCrashlytics.instance.setUserIdentifier(user.userId.toString());
          FirebaseCrashlytics.instance.setCustomKey("role", "management");
          FirebaseCrashlytics.instance.setCustomKey("platform", Platform.operatingSystem);
          FirebaseCrashlytics.instance.setCustomKey("branchId", user.branchId.toString());

          await AuthRepository.saveToken(token);
          _token = token;
          state = const AsyncValue.data(true);
        } else {
          state = const AsyncValue.data(false);
        }
      } else {
        state = AsyncValue.data(false);
        throw Exception('Login failed');
      }
    } on ApiException catch (e) {
      state = AsyncValue.error(e, StackTrace.current);
      Helper.showSnackBar(context, e.toString());
    }
  }

  void logout() async {

    ///log the user details who is logging out
    FirebaseCrashlytics.instance.log("User logging out");
    // 🔥 Force sending context BEFORE clearing user
    FirebaseCrashlytics.instance.recordError(
      "UserLogout",
      StackTrace.current,
      reason: "User initiated logout",
      fatal: false,
    );


    ///clear all th data
    ref.read(userProvider.notifier).logout(); //delete user hive box
    await AuthRepository.removeToken(); // delete token from sharedprefrence
    await NotificationServices().deleteToken();

    // 🔥 Clear crashlytics user context
    FirebaseCrashlytics.instance.setUserIdentifier("");
    FirebaseCrashlytics.instance.setCustomKey("role", "");
    FirebaseCrashlytics.instance.setCustomKey("branchId", "");

    _token = null;
    state = const AsyncValue.data(false);
    logger.e("user logged out");
  }

